# ============================================================
# AMIBOOK — Environment Variables
# Salin file ini: cp .env.example .env
# Lalu isi dengan kredensial Supabase kamu
# ============================================================

# Dapatkan dari: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Catatan:
# - Jangan pernah commit file .env ke GitHub!
# - File .env sudah masuk .gitignore secara default
# - Di Vercel, tambahkan variabel ini di: Settings → Environment Variables
